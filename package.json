{
  "name": "error-buzz",
  "displayName": "error-buzz",
  "description": "",
  "version": "1.0.0",
  "engines": {
  "vscode": "^1.109.0"
},
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
  "commands": [
    {
      "command": "error-buzz.selectSound",
      "title": "Select Error Buzz Sound"
    },
    {
      "command": "error-buzz.toggle",
      "title": "Toggle Error Buzz"
    }
  ],
  "configuration": {
    "title": "Error Buzz",
    "properties": {
      "errorBuzz.enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable or disable error sound."
      }
    }
  }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  },
  "publisher": "Coder-Z",

  "repository": {
  "type": "git",
  "url": "https://https://github.com/muzaif-xviii/error-buzz"
}
}
